<table width="100%" cellpadding="0" cellspacing="0" role="presentation" style="background-color:#1E40AF;">
  <tr>
    <td align="center" style="padding:28px 40px;">
      {{#if info.logo}}
        <img src="{{info.logo}}" alt="{{appName}}" height="40" style="display:block;border:0;height:40px;max-width:180px;object-fit:contain;" />
      {{else}}
        <span style="font-family:'Inter',Roboto,Arial,sans-serif;font-size:22px;font-weight:700;color:#ffffff;letter-spacing:-0.5px;">
          {{appName}}
        </span>
      {{/if}}
    </td>
  </tr>
</table>
