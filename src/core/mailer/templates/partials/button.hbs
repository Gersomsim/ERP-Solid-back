<table cellpadding="0" cellspacing="0" role="presentation" style="margin:0 auto;">
  <tr>
    <td align="center" style="border-radius:8px;background-color:{{#if color}}{{color}}{{else}}#1E40AF{{/if}};">
      <a href="{{url}}"
         target="_blank"
         style="display:inline-block;padding:14px 32px;font-family:'Inter',Roboto,Arial,sans-serif;font-size:15px;font-weight:600;color:#ffffff;text-decoration:none;border-radius:8px;letter-spacing:0.2px;">
        {{label}}
      </a>
    </td>
  </tr>
</table>
